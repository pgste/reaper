    {"name": "skip-level director reads via chain", "principal": "dir-dana", "action": "read", "resource": "salary-jo", "expect": "allow"},
    {"name": "HR cannot read (only update)", "principal": "hr-pat", "action": "read", "resource": "salary-jo", "expect": "deny"},
    {"name": "HR updates compensation", "principal": "hr-pat", "action": "update", "resource": "salary-jo", "expect": "allow"},
    {"name": "employee cannot update own compensation", "principal": "emp-jo", "action": "update", "resource": "salary-jo", "expect": "deny"}
  ]
