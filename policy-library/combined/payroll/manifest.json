{
  "name": "Payroll access (OPA 'read own salary' classic + manager chain)",
  "source": "OPA docs policy examples ('allow if input.user == employee or manager')",
  "policy": "policy.reap",
  "data": "data.json",
  "cases": [
    {"name": "employee reads own salary", "principal": "emp-jo", "action": "read", "resource": "salary-jo", "expect": "allow"},
