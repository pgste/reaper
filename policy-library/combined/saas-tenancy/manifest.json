{
  "name": "Multi-tenant SaaS (ABAC wall + ReBAC sharing + RBAC roles)",
  "source": "B2B SaaS authorization patterns (Oso/Auth0 multi-tenancy guides)",
  "policy": "policy.reap",
  "data": "data.json",
  "cases": [
    {"name": "squad member works in project", "principal": "amy", "action": "write", "resource": "proj-acme-1", "expect": "allow"},
