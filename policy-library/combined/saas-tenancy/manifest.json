    {"name": "watcher write denied", "principal": "walt", "action": "write", "resource": "proj-acme-1", "expect": "deny"},
    {"name": "tenant admin manages anything in tenant", "principal": "adam", "action": "delete", "resource": "proj-acme-1", "expect": "allow"},
    {"name": "cross-tenant member blocked by ABAC wall", "principal": "zoe", "action": "read", "resource": "proj-acme-1", "expect": "deny"},
    {"name": "cross-tenant admin ALSO blocked", "principal": "adam", "action": "read", "resource": "proj-zenith-1", "expect": "deny"},
    {"name": "support reads cross-tenant WITH ticket", "principal": "sue", "action": "read", "resource": "proj-acme-1", "context": {"ticket": "INC-1234"}, "expect": "allow"},
    {"name": "support without ticket denied", "principal": "sue", "action": "read", "resource": "proj-acme-1", "expect": "deny"},
    {"name": "support can never write", "principal": "sue", "action": "write", "resource": "proj-acme-1", "context": {"ticket": "INC-1234"}, "expect": "deny"}
  ]
