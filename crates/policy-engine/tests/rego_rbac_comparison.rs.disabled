//! Rego RBAC Comparison Test
//!
//! This test demonstrates the gap between Rego's data-driven RBAC
//! and Reaper's current capabilities, plus a roadmap to close it.
//!
//! Rego Policy (5-27µs):
//! - User -> Role bindings in data
//! - Role -> Permission mappings in data
//! - Policy queries data during evaluation
//!
//! Reaper Current State:
//! - DataStore can hold all the data ✅
//! - Fast indexed queries ✅
//! - Policy evaluation separate from data ❌
//! - No entity relationship queries ❌

use policy_engine::data::{DataStore, Entity, EntityBuilder, IndexStrategy};
use policy_engine::{PolicyAction, PolicyRequest, PolicyRule, SimplePolicyEvaluator};
use std::collections::HashMap;

#[test]
fn test_rego_rbac_data_model() {
    println!("\n╔════════════════════════════════════════════════════════════════╗");
    println!("║  Rego RBAC vs Reaper: Gap Analysis                            ║");
    println!("╚════════════════════════════════════════════════════════════════╝\n");

    // ================================================================
    // STEP 1: Load Rego's data model into Reaper DataStore
    // ================================================================
    println!("STEP 1: Loading Rego data model into DataStore\n");

    let mut store = DataStore::new();

    // Load user-role bindings (alice -> [dev, test], bob -> [test])
    let alice_dev = EntityBuilder::new("alice_dev", "user_role_binding")
        .with_attribute("user", "alice")
        .with_attribute("role", "dev")
        .build();

    let alice_test = EntityBuilder::new("alice_test", "user_role_binding")
        .with_attribute("user", "alice")
        .with_attribute("role", "test")
        .build();

    let bob_test = EntityBuilder::new("bob_test", "user_role_binding")
        .with_attribute("user", "bob")
        .with_attribute("role", "test")
        .build();

    store.add_entity(alice_dev).unwrap();
    store.add_entity(alice_test).unwrap();
    store.add_entity(bob_test).unwrap();

    // Load role-permission mappings
    let dev_write = EntityBuilder::new("dev_write_foo123", "role_permission")
        .with_attribute("role", "dev")
        .with_attribute("resource", "foo123")
        .with_attribute("action", "write")
        .build();

    let dev_read = EntityBuilder::new("dev_read_foo123", "role_permission")
        .with_attribute("role", "dev")
        .with_attribute("resource", "foo123")
        .with_attribute("action", "read")
        .build();

    let test_read = EntityBuilder::new("test_read_foo123", "role_permission")
        .with_attribute("role", "test")
        .with_attribute("resource", "foo123")
        .with_attribute("action", "read")
        .build();

    store.add_entity(dev_write).unwrap();
    store.add_entity(dev_read).unwrap();
    store.add_entity(test_read).unwrap();

    println!("✅ Data loaded:");
    println!("  - User-role bindings: 3");
    println!("  - Role-permission mappings: 3");
    println!("  - Total entities: {}\n", store.count());

    // Create indexes for fast queries
    store
        .create_index(
            "user_idx",
            "user_role_binding",
            "user",
            IndexStrategy::Equality,
        )
        .unwrap();

    store
        .create_index(
            "role_perm_idx",
            "role_permission",
            "role",
            IndexStrategy::Equality,
        )
        .unwrap();

    println!("✅ Indexes created for fast lookups\n");

    // ================================================================
    // STEP 2: Query Pattern - What Rego Does
    // ================================================================
    println!("STEP 2: Rego's Evaluation Pattern\n");
    println!("Rego pseudocode:");
    println!("  1. user_roles = find_all(bindings where user == subject)");
    println!("  2. for each role in user_roles:");
    println!("  3.   permissions = find_all(roles where role == role_name)");
    println!("  4.   if any permission matches (resource, action): ALLOW");
    println!("  5. default: DENY\n");

    // ================================================================
    // STEP 3: What Works in Reaper Today
    // ================================================================
    println!("STEP 3: What Works in Reaper Today ✅\n");

    // We can query the data!
    let subject = "bob";
    let resource = "foo123";
    let action = "write";

    // Query 1: Find bob's roles
    let user_roles: Vec<_> = store
        .query_by_attribute("user_role_binding", "user", subject)
        .into_iter()
        .map(|entity| entity.attributes.get("role").unwrap().as_string().unwrap())
        .collect();

    println!("Query 1: Bob's roles = {:?}", user_roles);

    // Query 2: Find permissions for bob's roles
    let mut has_permission = false;
    for role in &user_roles {
        let permissions = store.query_by_attribute("role_permission", "role", role);

        for perm in permissions {
            let perm_resource = perm
                .attributes
                .get("resource")
                .unwrap()
                .as_string()
                .unwrap();
            let perm_action = perm.attributes.get("action").unwrap().as_string().unwrap();

            if perm_resource == resource && perm_action == action {
                has_permission = true;
                break;
            }
        }
    }

    println!(
        "Query 2: Bob has permission for {}/{}: {}",
        resource, action, has_permission
    );
    println!("\n✅ Data queries work perfectly!\n");

    // ================================================================
    // STEP 4: What Doesn't Work - Policy Integration ❌
    // ================================================================
    println!("STEP 4: What Doesn't Work - Policy Integration ❌\n");

    println!("Problem: SimplePolicyEvaluator can't query DataStore\n");
    println!("Current evaluator signature:");
    println!("  fn evaluate(&self, request: &PolicyRequest) -> Result<PolicyAction>");
    println!("              ^^^^ No DataStore parameter!\n");

    println!("PolicyRule structure:");
    println!("  struct PolicyRule {{");
    println!("    action: PolicyAction,");
    println!("    resource: String,");
    println!("    conditions: Vec<String>,  // Static conditions only");
    println!("  }}\n");

    println!("❌ Can't express: 'Allow if user has role with permission'\n");

    // ================================================================
    // STEP 5: Gap Analysis
    // ================================================================
    println!("STEP 5: Gap Analysis\n");
    println!("┌────────────────────────────────────────┬─────────┬─────────┐");
    println!("│ Feature                                │  Rego   │ Reaper  │");
    println!("├────────────────────────────────────────┼─────────┼─────────┤");
    println!("│ Load external data                     │   ✅    │   ✅    │");
    println!("│ Fast indexed queries                   │   ✅    │   ✅    │");
    println!("│ Entity relationships (joins)           │   ✅    │   ✅    │");
    println!("│ Policy queries data during eval        │   ✅    │   ❌    │");
    println!("│ Set comprehensions                     │   ✅    │   ❌    │");
    println!("│ Multi-step reasoning                   │   ✅    │   ❌    │");
    println!("└────────────────────────────────────────┴─────────┴─────────┘\n");

    // ================================================================
    // STEP 6: Proposed Solutions
    // ================================================================
    println!("STEP 6: Proposed Solutions\n");

    println!("Option 1: Pre-compute Permission Matrix (FASTEST)");
    println!("  - Flatten user->role->permission into user->permission");
    println!("  - Store as entities in DataStore");
    println!("  - Single indexed lookup: O(1)");
    println!("  - Performance: ~100-500ns (faster than Rego!)");
    println!("  - Tradeoff: Extra storage, denormalized data\n");

    println!("Option 2: Attribute-Enriched Requests (SIMPLE)");
    println!("  - Pre-query user roles before evaluation");
    println!("  - Add to request.context[\"roles\"]");
    println!("  - Policy checks context[\"roles\"]");
    println!("  - Performance: ~1-5µs (query + eval)");
    println!("  - Tradeoff: Extra pre-processing step\n");

    println!("Option 3: DataStore-Aware Evaluator (FLEXIBLE)");
    println!("  - New evaluator type with DataStore access");
    println!("  - Can query during evaluation");
    println!("  - Full Rego-like expressiveness");
    println!("  - Performance: ~5-10µs (multiple queries)");
    println!("  - Tradeoff: More complex, slower\n");

    println!("Option 4: Native RBAC Evaluator (RECOMMENDED)");
    println!("  - Purpose-built for RBAC pattern");
    println!("  - Understands user->role->permission");
    println!("  - Optimized query plan");
    println!("  - Performance: ~1-3µs (competitive with Rego)");
    println!("  - Tradeoff: Domain-specific\n");

    assert!(
        has_permission == false,
        "Bob should NOT have write permission"
    );
    println!("✅ Test complete - Bob correctly denied write access\n");
}

/// Demonstrates Option 1: Pre-computed Permission Matrix
#[test]
fn test_precomputed_permission_matrix() {
    println!("\n╔════════════════════════════════════════════════════════════════╗");
    println!("║  Option 1: Pre-computed Permission Matrix (FASTEST)           ║");
    println!("╚════════════════════════════════════════════════════════════════╝\n");

    let mut store = DataStore::new();

    // Pre-compute: For each user, flatten all their permissions
    // alice -> dev -> write/read foo123
    // alice -> test -> read foo123
    // bob -> test -> read foo123

    let alice_write = EntityBuilder::new("alice_write_foo123", "user_permission")
        .with_attribute("user", "alice")
        .with_attribute("resource", "foo123")
        .with_attribute("action", "write")
        .build();

    let alice_read = EntityBuilder::new("alice_read_foo123", "user_permission")
        .with_attribute("user", "alice")
        .with_attribute("resource", "foo123")
        .with_attribute("action", "read")
        .build();

    let bob_read = EntityBuilder::new("bob_read_foo123", "user_permission")
        .with_attribute("user", "bob")
        .with_attribute("resource", "foo123")
        .with_attribute("action", "read")
        .build();

    store.add_entity(alice_write).unwrap();
    store.add_entity(alice_read).unwrap();
    store.add_entity(bob_read).unwrap();

    // Create composite index on (user, resource, action)
    store
        .create_index(
            "user_perm_idx",
            "user_permission",
            "user",
            IndexStrategy::Equality,
        )
        .unwrap();

    println!("✅ Pre-computed permission matrix loaded\n");

    // Evaluation: Single query!
    let start = std::time::Instant::now();

    let user = "bob";
    let resource = "foo123";
    let action = "write";

    let permissions = store.query_by_attribute("user_permission", "user", user);
    let has_permission = permissions.iter().any(|perm| {
        perm.attributes
            .get("resource")
            .unwrap()
            .as_string()
            .unwrap()
            == resource
            && perm.attributes.get("action").unwrap().as_string().unwrap() == action
    });

    let elapsed = start.elapsed();

    println!(
        "Query: Does {} have {} permission on {}?",
        user, action, resource
    );
    println!("Result: {}", if has_permission { "ALLOW" } else { "DENY" });
    println!("Time: {:?}\n", elapsed);

    println!("Performance Analysis:");
    println!("  - Single indexed query: O(1)");
    println!("  - No joins required");
    println!("  - Expected: 100-500ns");
    println!("  - Actual: {:?}", elapsed);
    println!(
        "  - Comparison: {}x faster than Rego (5-27µs)\n",
        5000.0 / elapsed.as_nanos() as f64
    );

    println!("Tradeoffs:");
    println!("  ✅ Fastest possible evaluation");
    println!("  ✅ Simple policy logic");
    println!("  ❌ Denormalized data (more storage)");
    println!("  ❌ Must rebuild on role changes\n");

    assert!(!has_permission);
    println!("✅ Test passed - Bob correctly denied\n");
}

#[test]
fn test_performance_comparison() {
    println!("\n╔════════════════════════════════════════════════════════════════╗");
    println!("║  Performance Comparison: Rego vs Reaper Approaches            ║");
    println!("╚════════════════════════════════════════════════════════════════╝\n");

    println!("Rego Performance (from user's data):");
    println!("  - Evaluation time: 5-27µs");
    println!("  - Pattern: Multi-step queries + reasoning\n");

    println!("Reaper Options:\n");

    println!("┌────────────────────────────┬──────────────┬─────────────┬──────────────┐");
    println!("│ Approach                   │ Complexity   │ Est. Time   │ vs Rego      │");
    println!("├────────────────────────────┼──────────────┼─────────────┼──────────────┤");
    println!("│ Pre-computed Matrix        │ O(1)         │ 100-500ns   │ 10-270x faster │");
    println!("│ Attribute-Enriched Request │ O(m)         │ 1-5µs       │ 1-27x faster │");
    println!("│ DataStore-Aware Evaluator  │ O(m*n)       │ 5-10µs      │ Same speed   │");
    println!("│ Native RBAC Evaluator      │ O(m)         │ 1-3µs       │ 2-27x faster │");
    println!("└────────────────────────────┴──────────────┴─────────────┴──────────────┘\n");

    println!("where m = avg roles per user, n = avg permissions per role\n");

    println!("Recommendation:");
    println!("  For RBAC specifically: Pre-computed Matrix or Native RBAC Evaluator");
    println!("  For general data-driven policies: DataStore-Aware Evaluator\n");
}
